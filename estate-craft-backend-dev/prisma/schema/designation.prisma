model Designation {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?
  status      Status   @default(ACTIVE)
  sNo         Int      @default(autoincrement())
  description String?
  displayName String?
  meta        Json?
  users       User[]

  @@index([status])
  @@index([name])
}
