model User {
  id                    String           @id @default(uuid())
  sNo                   Int              @default(autoincrement())
  name                  String
  email                 String           @unique
  phoneNumber           String           @unique
  password              String?
  department            String?
  startDate             DateTime?        @default(now())
  lastActive            DateTime?
  organization          String?
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  roleId                String
  status                Status           @default(ACTIVE)
  createdAt             DateTime         @default(now())
  createdBy             String?
  updatedAt             DateTime?        @updatedAt
  updatedBy             String?
  userType              UserType         @default(INTERNAL)
  inviteState           UserInviteState?
  reason                String?
  clientId              String?
  vendorId              String?
  invitedBy             String?
  designationId         String?
  reportsToId           String?
  profilePhoto          String?
  Activities            Activities[]
  assignUsers           AssignUser[]
  createdAttachments    Attachment[]     @relation("createdByUser")
  updatedAttachments    Attachment[]     @relation("updatedByUser")
  comments              Comment[]
  createdDeliverables   Deliverable[]    @relation("createdByUser")
  updatedDeliverables   Deliverable[]    @relation("updatedByUser")
  createdFolders        Folder[]         @relation("createdByUser")
  updatedFolders        Folder[]         @relation("updatedByUser")
  createdMOMs           MOM[]            @relation("createdByUser")
  updatedMOMs           MOM[]            @relation("updatedByUser")
  sentNotifications     Notification[]   @relation("NotificationActor")
  receivedNotifications Notification[]   @relation("UserNotifications")
  createdPayments       Payment[]        @relation("createdByUser")
  updatedPayments       Payment[]        @relation("updatedByUser")
  managedProjects       Project[]        @relation("ProjectManager")
  projectUsers          ProjectUser[]
  createdQuotations     Quotation[]      @relation("createdByUser")
  updatedQuotations     Quotation[]      @relation("updatedByUser")
  assignedSnags         Snag[]           @relation("assignedByUser")
  assignedToSnags       Snag[]           @relation("assignedToUser")
  createdSnags          Snag[]           @relation("createdByUser")
  updatedSnags          Snag[]           @relation("updatedByUser")
  assignedBySubTasks    SubTask[]        @relation("subTaskAssignedByUser")
  assigneeSubTasks      SubTask[]        @relation("subTaskAssigneeUser")
  assignedByTasks       Task[]           @relation("assignedByUser")
  assigneeTasks         Task[]           @relation("assigneeUser")
  approvedTasks         Task[]           @relation("approvedByUser")
  TaskAssignee          TaskAssignee[]
  createdTimelines      Timeline[]       @relation("UserCreatedTimelines")
  sentTo                Timeline[]       @relation("UserSentTo")
  client                Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  designation           Designation?     @relation(fields: [designationId], references: [id])
  InvitedBy             User?            @relation("UserInvitedBy", fields: [invitedBy], references: [id])
  InvitedUsers          User[]           @relation("UserInvitedBy")
  ReportsTo             User?            @relation("UserReportsTo", fields: [reportsToId], references: [id], onDelete: SetNull)
  DirectReports         User[]           @relation("UserReportsTo")
  role                  Role             @relation(fields: [roleId], references: [id])
  vendor                Vendor?          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  momAttendees          momAttendees[]
  projects              Project[]        @relation("ProjectClientContacts")
  teamProjects          Project[]        @relation("ProjectToUser")
  timesheets            Timesheet[]

  siteVisitAssignments                   SiteVisitEngineer[]           @relation("SiteVisitEngineer")
  siteVisitGalleryCollectionsCreated    SiteVisitGalleryCollection[]
  timesheetWeeks                         TimesheetWeek[]
  timesheetApproverAssignmentsAsEmployee TimesheetApproverAssignment[] @relation("TimesheetApproverEmployee")
  timesheetApproverAssignmentsAsApprover TimesheetApproverAssignment[] @relation("TimesheetApproverApprover")
  timesheetDecisionLogsAsActor           TimesheetDecisionLog[]        @relation("TimesheetDecisionActor")
  timesheetReminderLogs                  TimesheetReminderLog[]        @relation("TimesheetReminderUser")
}

enum Status {
  ACTIVE
  INACTIVE
}

enum UserType {
  INTERNAL
  CLIENT
  CLIENT_CONTACT
  VENDOR
  VENDOR_CONTACT
}

enum UserInviteState {
  SENT
  ACCEPTED
  PASSWORD_ADDED
  REJECTED
  COMPLETED
}
