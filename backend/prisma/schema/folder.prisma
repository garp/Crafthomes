model Folder {
  id             String       @id @default(uuid())
  name           String       @unique
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      String?
  updatedBy      String?
  status         FolderStatus @default(ACTIVE)
  parentFolderId String?
  projectId      String?
  attachments    Attachment[]
  CreatedBy      User?        @relation("createdByUser", fields: [createdBy], references: [id])
  parentFolder   Folder?      @relation("FolderToFolder", fields: [parentFolderId], references: [id])
  subfolders     Folder[]     @relation("FolderToFolder")
  project        Project?     @relation(fields: [projectId], references: [id])
  UpdatedBy      User?        @relation("updatedByUser", fields: [updatedBy], references: [id])
}

enum FolderStatus {
  ACTIVE
  ARCHIVED
  DELETED
}
