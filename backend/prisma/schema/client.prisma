model Client {
  id               String      @id @default(uuid())
  name             String
  phoneNumber      String
  email            String
  status           Status      @default(ACTIVE)
  sNo              Int         @default(autoincrement())
  createdAt        DateTime    @default(now())
  createdBy        String?
  updatedAt        DateTime    @updatedAt
  updatedBy        String?
  clientType       ClientType  @default(INDIVIDUAL)
  gstIn            String?
  organizationName String?
  panDetails       String?
  Address          Address[]
  Payment          Payment[]
  Project          Project[]
  Quotation        Quotation[]
  user             User[]
}

enum ClientType {
  INDIVIDUAL
  ORGANIZATION
}
