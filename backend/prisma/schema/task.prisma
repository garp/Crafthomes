model Task {
  id                          String                        @id @default(uuid())
  name                        String
  assignedBy                  String?
  assignee                    String?
  createdAt                   DateTime                      @default(now())
  notes                       String?
  priority                    Priority?
  sNo                         Int                           @default(autoincrement())
  updatedAt                   DateTime                      @updatedAt
  createdBy                   String?
  phaseId                     String?
  projectId                   String?
  progress                    Int?
  taskStatus                  TaskStatus?                   @default(PENDING)
  approvalStatus              TaskApprovalStatus?           @default(PENDING)
  approvedBy                  String?
  approvedAt                  DateTime?
  unit                        String?
  updatedBy                   String?
  status                      Status?                       @default(ACTIVE)
  description                 String?
  endDate                     DateTime?
  startDate                   DateTime?
  plannedEnd                  DateTime?
  plannedStart                DateTime?
  duration                    Int?
  dueDate                     DateTime?
  Activities                  Activities[]
  attachments                 Attachment[]
  comments                    Comment[]
  Deliverables                Deliverable[]
  subTasks                    SubTask[]
  assignedByUser              User?                         @relation("assignedByUser", fields: [assignedBy], references: [id])
  assigneeUser                User?                         @relation("assigneeUser", fields: [assignee], references: [id])
  approvedByUser              User?                         @relation("approvedByUser", fields: [approvedBy], references: [id])
  phase                       Phase?                        @relation(fields: [phaseId], references: [id])
  project                     Project?                      @relation(fields: [projectId], references: [id])
  TaskAssignee                TaskAssignee[]
  dependentTasks              TaskPredecessor[]             @relation("PredecessorOf")
  predecessors                TaskPredecessor[]             @relation("TaskPredecessors")
  TimeLineTaskOrder           TimeLineTaskOrder[]
  TimesheetTask               TimesheetTask[]
  siteVisitTaskSnapshots      SiteVisitTaskSnapshot[]
  siteVisitGalleryAttachments SiteVisitGalleryAttachment[]

  @@index([phaseId])
  @@index([projectId])
  @@index([status, createdAt])
  @@index([taskStatus])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum TaskApprovalStatus {
  PENDING
  APPROVED
}
