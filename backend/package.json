{
  "name": "estate-craft-backend",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "homepage": "https://github.com/bytive/estate-craft-backend#readme",
  "bugs": {
    "url": "https://github.com/bytive/estate-craft-backend/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bytive/estate-craft-backend.git"
  },
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "prisma": {
    "schema": "prisma/schema",
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=dev node src/index.js",
    "dev": "cross-env NODE_ENV=dev nodemon --no-warnings src/index.js",
    "prod": "cross-env NODE_ENV=prod node src/index.js",
    "test": "cross-env NODE_ENV=dev node src/index.js",
    "test-stage": "cross-env NODE_ENV=dev nodemon src/index.js",
    "stage": "cross-env NODE_ENV=dev node src/index.js",
    "prettier": "prettier --write \"src/\" && prettier --write \"config/\"",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "prisma:generate": "prisma generate --schema=./prisma/schema",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema",
    "prisma:studio": "prisma studio --schema=./prisma/schema",
    "prisma:format": "prisma format --schema=./prisma/schema",
    "seed": "prisma db seed --schema=./prisma/schema --",
    "seed:modora": "prisma db seed --schema=./prisma/schema -- --modora",
    "reset-data:view": "node scripts/reset-data.js --view",
    "reset-data:delete": "node scripts/reset-data.js --delete",
    "reset-data:delete:modora": "node scripts/reset-data.js --delete --modora"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "firebase": "^12.9.0",
    "form-data": "^4.0.5",
    "joi": "^17.13.3",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mongodb": "^7.0.0",
    "morgan": "^1.10.0",
    "morgan-body": "^2.6.9",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.9",
    "pg": "^8.16.3",
    "redis": "^5.8.3",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.5",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "prisma": "^6.17.1"
  }
}
